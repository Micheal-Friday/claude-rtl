{
  "name": "claude-rtl",
  "version": "1.0.0",
  "description": "Right-to-left Persian/Arabic support for claude.ai (Firefox & Chrome).",
  "private": true,
  "scripts": {
    "lint:firefox": "web-ext lint --source-dir=firefox",
    "build:firefox": "web-ext build --source-dir=firefox --artifacts-dir=dist --overwrite-dest",
    "build:chrome": "web-ext build --source-dir=chrome --artifacts-dir=dist --overwrite-dest"
  },
  "devDependencies": {
    "web-ext": "10.3.0"
  }
}
