{
  "manifest_version": 2,
  "name": "Claude RTL (Persian & Arabic)",
  "version": "1.0.0",
  "description": "Automatic right-to-left text direction for Persian and Arabic text on claude.ai. Keeps code blocks LTR.",
  "browser_specific_settings": {
    "gecko": {
      "id": "claude-rtl-persian-arabic@addons",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["storage"],
  "icons": {
    "48": "icon.svg",
    "128": "icon.svg"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Claude RTL",
    "default_icon": {
      "48": "icon.svg",
      "128": "icon.svg"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://claude.ai/*", "*://*.claude.ai/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
